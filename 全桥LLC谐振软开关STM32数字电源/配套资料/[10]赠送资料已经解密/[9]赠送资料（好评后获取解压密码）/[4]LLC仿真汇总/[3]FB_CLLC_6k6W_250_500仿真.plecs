            Value         "12.5e-6"
            Show          off
          }
          Parameter {
            Variable      "Parameters"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#include <float.h> \n#include <math.h> \n\n//\n//De"
"fine Control funciton coefficient\n// Vloop\n#define vLOOP_B0               -"
"0.323\n#define vLOOP_B1                0.6401\n#define vLOOP_B2              "
" -0.3194\n#define vLOOP_A1               -1.398\n#define vLOOP_A2            "
"    0.3979\n#define vLOOP_OUTMAX            300\n#define vLOOP_OUTMIN        "
"    60\n\n// Iloop \n#define iLOOP_B0               -7.9795\n#define iLOOP_B1"
"                15.8154\n#define iLOOP_B2               -7.8917\n#define iLOO"
"P_A1               -1.398\n#define iLOOP_A2                0.3979\n#define iL"
"OOP_OUTMAX            300\n#define iLOOP_OUTMIN            60\n\n\n// Control"
" law 2p2z data define\ntypedef struct CONTROL_LAW_2P2Z_TAG {\n    double B0;"
"\n    double B1;\n    double B2;\n    double A1;\n    double A2;\n    double "
"out_max;\n    double out_min;\n\n    double error_0;\n    double error_1;\n  "
"  double error_2;\n    double output_0;\n    double output_1;\n    double out"
"put_2;\n}CONTROL_LAW_2P2Z_DEFINE;\n\ntypedef struct CONTROL_LAW_3P3Z_TAG {\n"
"\t double B0;\n    double B1;\n    double B2;\n    double B3;\n\n    double A"
"1;\n    double A2;\n    double A3;\n\n    double out_max;\n    double out_min"
";\n\n     double error_0;\n     double error_1;\n     double error_2;\n     d"
"ouble error_3;\n\n     double output_0;\n     double output_1;\n     double o"
"utput_2;\n     double output_3;\n\n    double return_result;\n}CONTROL_LAW_3P"
"3Z_DEFINE;\n\n\ndouble Control_law_3p3z_func(CONTROL_LAW_3P3Z_DEFINE *ctrl_la"
"w, double target_reality_value, double control_give_value)\n{\t   //\n     //"
" calculate the error\n     //\n    ctrl_law->error_0 =  control_give_value - "
"target_reality_value;\n\n    //\n    // Discrete difference equation\n    //"
"\n    ctrl_law->output_0 = (ctrl_law->B0 * ctrl_law->error_0  + ctrl_law->B1 "
"* ctrl_law->error_1 \\\n                       +  ctrl_law->B2 * ctrl_law->er"
"ror_2  + ctrl_law->B3 * ctrl_law->error_3 \\\n                       -  ctrl_"
"law->A1 * ctrl_law->output_1 - ctrl_law->A2 * ctrl_law->output_2 \\\n        "
"               -  ctrl_law->A3 * ctrl_law->output_3);\n\n    //\n    // 3p3z "
"function integral limit\n    //\n //   ctrl_law->output_0 = fmaxf((fminf(ctrl"
"_law->output_0, ctrl_law->out_max)), ctrl_law->out_min);\n\n    //\n    // Up"
"date last cycle value\n    //\n    ctrl_law->output_1 = ctrl_law->output_0;\n"
"    ctrl_law->output_2 = ctrl_law->output_1;\n    ctrl_law->output_3 = ctrl_l"
"aw->output_2;\n\n    ctrl_law->error_1 = ctrl_law->error_0;\n    ctrl_law->er"
"ror_2 = ctrl_law->error_1;\n    ctrl_law->error_3 = ctrl_law->error_2;\n\n   "
" //\n    // output limit\n    //\n //   ctrl_law->return_result = (ctrl_law->"
"out_max - ctrl_law->output_0);\n    ctrl_law->return_result = (ctrl_law->outp"
"ut_0);\n    ctrl_law->return_result = (fmaxf((fminf(ctrl_law->return_result, "
"ctrl_law->out_max)), ctrl_law->out_min));\n\n    //\n    // Return calculate "
"result\n    //\n    return(ctrl_law->return_result);\n}\n\ndouble Control_law"
"_2p2z_func(CONTROL_LAW_2P2Z_DEFINE *ctrl_law, double target_reality_value, do"
"uble control_give_value)\n{                                                  "
"                                      \n    // calculate the error\n    ctrl_"
"law->error_0 = control_give_value - target_reality_value;\n    \n \n    //\n "
"   // y[n] = B0 * e[n] + B1 * e[n-1] + B2 * e[n-2]  - A1 * y[n-1]  - A2 * y[n"
"-2]\n    // Discrete difference equation\n    //\n    ctrl_law->output_0 = (c"
"trl_law->B0 * ctrl_law->error_0 + ctrl_law->B1 * ctrl_law->error_1 \\\n      "
"                  + ctrl_law->B2 * ctrl_law->error_2  - ctrl_law->A1 * ctrl_l"
"aw->output_1 \\\n                        - ctrl_law->A2 * ctrl_law->output_2)"
" ;\n\n    //\n    // output  integral limit\n    //\n    if(ctrl_law->output_"
"0 > ctrl_law->out_max)   { ctrl_law->output_0 = ctrl_law->out_max; }\n\n    i"
"f(ctrl_law->output_0 < ctrl_law->out_min)   { ctrl_law->output_0 = ctrl_law->"
"out_min; }\n\n    //\n    // Update last cycle value\n    //\n    ctrl_law->o"
"utput_1 = ctrl_law->output_0;\n    ctrl_law->output_2 = ctrl_law->output_1;\n"
"\n    ctrl_law->error_1 = ctrl_law->error_0;\n    ctrl_law->error_2 = ctrl_la"
"w->error_1;\n    \n    return(ctrl_law->output_0);\n}\n\n\n//\n// Control dat"
"a define \n//\n\nCONTROL_LAW_2P2Z_DEFINE vloop_2p2z_data = {\n    vLOOP_B0,  "
"           \n    vLOOP_B1,               \n    vLOOP_B2,               \n    "
"vLOOP_A1,              \n    vLOOP_A2,               \n    vLOOP_OUTMAX,     "
"   \n    vLOOP_OUTMIN, \n    0, 0, 0, 0, 0, 0\n};\n\n\nCONTROL_LAW_2P2Z_DEFIN"
"E iloop_2p2z_data = {\n    iLOOP_B0,             \n    iLOOP_B1,             "
"  \n    iLOOP_B2,               \n    iLOOP_A1,              \n    iLOOP_A2, "
"              \n    iLOOP_OUTMAX,        \n    iLOOP_OUTMIN, \n    0, 0, 0, 0"
", 0, 0\n};"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "// Define IO\ndouble vsen = InputSignal(0, 0);\ndou"
"ble vset = InputSignal(0, 1);\n\ndouble isen = InputSignal(0, 2);\ndouble ise"
"t = InputSignal(0, 3);\n\n\n//\n// 2P2Z func\n//\ndouble vloop_out = Control_"
"law_2p2z_func(&vloop_2p2z_data, vsen, vset);\n\ndouble iloop_out = Control_la"
"w_2p2z_func(&iloop_2p2z_data, isen, iset);\n\n//\n//output small value\n//\nd"
"ouble control_value = fmaxf(vloop_out, iloop_out);\n\n//output control value "
"\nOutputSignal(0, 0) = control_value;\n\n//\n// For Debug\n//\nOutputSignal(0"
", 1) = vloop_out;\nOutputSignal(0, 2) = iloop_out;\n\n"
            Show          off
          }
