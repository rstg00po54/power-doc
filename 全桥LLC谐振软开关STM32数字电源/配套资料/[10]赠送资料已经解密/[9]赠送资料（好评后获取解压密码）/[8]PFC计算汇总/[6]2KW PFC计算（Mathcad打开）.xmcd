						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>当输入电压最小且输出满载功率时，输入电流最大</b>
						</p>
					</text>
				</region>
				<region region-id="9425" left="156" top="529.5" width="173.25" height="28.5" align-x="198.75" align-y="546" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="ac_max">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:id xml:space="preserve" subscript="out_max">P</ml:id>
									<ml:apply>
										<ml:mult/>
										<ml:apply>
											<ml:mult/>
											<ml:id xml:space="preserve">Eff</ml:id>
											<ml:id xml:space="preserve">PF</ml:id>
										</ml:apply>
										<ml:id xml:space="preserve" subscript="ac_min">V</ml:id>
									</ml:apply>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>19.33207674834469</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="9"/>
				</region>
				<region region-id="9419" left="114" top="573.75" width="243" height="9.75" align-x="123.75" align-y="582" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>计算输入电流最大值时的峰值与有效值</b>
						</p>
					</text>
				</region>
				<region region-id="9422" left="156" top="598.5" width="173.25" height="13.5" align-x="225" align-y="606" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="ac_max_peak">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:sqrt/>
										<ml:real>2</ml:real>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="ac_max">I</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>27.339685126346627</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="10"/>
				</region>
				<region region-id="9441" left="156" top="631.5" width="194.25" height="25.5" align-x="219.75" align-y="648" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="ac_max_avg">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:div/>
									<ml:apply>
										<ml:mult/>
										<ml:real>2</ml:real>
										<ml:id xml:space="preserve" subscript="ac_max_peak">I</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve">π</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>17.404984121736138</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="11"/>
				</region>
			</area>
			<rendering item-idref="12"/>
		</region>
		<region region-id="9451" left="78" top="727.5" width="174.75" height="12" align-x="103.5" align-y="738" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f size="12">
						<b>保险丝选型计算：</b>
					</f>
					<f size="10">
						<inlineAttr font-weight="normal">
							<sp/>
						</inlineAttr>
					</f>
				</p>
			</text>
		</region>
		<region region-id="9621" left="0" top="759" width="6000" align-x="6000" align-y="768" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="176.25">
			<area is-collapsed="false" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="9621" bottom-lock-id="9454" bottom-tag="">
				<region region-id="9521" left="102" top="789.75" width="531.75" height="9.75" align-x="111.75" align-y="798" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>输入保险丝选型原则为PFC工作最大电流平均值的1.5~2倍余量，取余量1.5倍,计算选型保险丝的额定电流值:</b>
						</p>
					</text>
				</region>
				<region region-id="9458" left="156" top="820.5" width="53.25" height="13.5" align-x="188.25" align-y="828" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="FUSE">K</ml:id>
							<ml:real>1.5</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="13"/>
				</region>
				<region region-id="9462" left="156" top="850.5" width="192" height="13.5" align-x="225" align-y="858" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="FUSE_Rating">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="FUSE">K</ml:id>
									<ml:id xml:space="preserve" subscript="ac_max">I</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>28.998115122517035</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="14"/>
				</region>
				<region region-id="9465" left="102" top="891.75" width="531.75" height="9.75" align-x="111.75" align-y="900" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>即理想保险丝选30A，耐压大于265VAC的保险丝</b>
						</p>
					</text>
				</region>
			</area>
			<rendering item-idref="15"/>
		</region>
		<region region-id="9471" left="78" top="961.5" width="174.75" height="12" align-x="103.5" align-y="972" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
