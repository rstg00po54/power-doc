				<region region-id="9430" left="156" top="448.5" width="182.25" height="13.5" align-x="225" align-y="456" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="ac_peak_min">V</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:sqrt/>
										<ml:real>2</ml:real>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="ac_min">V</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">V</ml:id>
