					<f size="12">
						<b>整流桥选型计算：</b>
					</f>
					<f size="10">
						<inlineAttr font-weight="normal">
							<sp/>
						</inlineAttr>
					</f>
				</p>
			</text>
		</region>
		<region region-id="9522" left="0" top="999" width="6000" align-x="6000" align-y="1008" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="404.25">
			<area is-collapsed="false" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="9522" bottom-lock-id="9520" bottom-tag="">
				<region region-id="9523" left="102" top="1029.75" width="531.75" height="19.5" align-x="111.75" align-y="1038" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>输入电流交流电经流经整流桥整流，即流过整流桥最大的电流为输入AC的最大电流，取1.5倍余量，计算选型整流桥的额定电流值：</b>
						</p>
					</text>
				</region>
				<region region-id="9474" left="162" top="1078.5" width="63.75" height="13.5" align-x="204.75" align-y="1086" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Bridge">K</ml:id>
							<ml:real>1.5</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="16"/>
				</region>
				<region region-id="9478" left="162" top="1114.5" width="234" height="13.5" align-x="241.5" align-y="1122" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Bridge_Rating">I</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="Bridge">K</ml:id>
									<ml:id xml:space="preserve" subscript="ac_max_avg">I</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">A</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>26.107476182604209</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="ampere"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="17"/>
				</region>
				<region region-id="9485" left="102" top="1143.75" width="531.75" height="9.75" align-x="111.75" align-y="1152" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>整流桥二极管截止时，其上的反向电压为BUS母线电压值，取1.3倍余量，计算选型整流桥耐压值</b>
						</p>
					</text>
				</region>
				<region region-id="9494" left="162" top="1174.5" width="69" height="13.5" align-x="210" align-y="1182" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Bridge">VK</ml:id>
							<ml:real>1.3</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="18"/>
				</region>
				<region region-id="9499" left="162" top="1204.5" width="189" height="13.5" align-x="241.5" align-y="1212" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Bridge_Rating">V</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="Bridge">VK</ml:id>
									<ml:id xml:space="preserve" subscript="bus">V</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">V</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>507</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="volt"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="19"/>
				</region>
				<region region-id="9502" left="102" top="1239.75" width="531.75" height="9.75" align-x="111.75" align-y="1248" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>计算整流桥最大损耗值：</b>
						</p>
					</text>
				</region>
				<region region-id="9508" left="102" top="1263.75" width="531.75" height="9.75" align-x="111.75" align-y="1272" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>计算整流桥导通时的管压降V_F为1V</b>
						</p>
					</text>
				</region>
				<region region-id="9510" left="162" top="1288.5" width="79.5" height="13.5" align-x="215.25" align-y="1296" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="F_Bridge">V</ml:id>
							<ml:apply>
								<ml:mult style="auto-select"/>
								<ml:real>0.9</ml:real>
								<ml:id xml:space="preserve">V</ml:id>
							</ml:apply>
						</ml:define>
					</math>
					<rendering item-idref="20"/>
				</region>
				<region region-id="9515" left="162" top="1318.5" width="216.75" height="13.5" align-x="204.75" align-y="1326" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Bridge">P</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:apply>
										<ml:mult/>
										<ml:real>2</ml:real>
										<ml:id xml:space="preserve" subscript="F_Bridge">V</ml:id>
									</ml:apply>
									<ml:id xml:space="preserve" subscript="ac_max_avg">I</ml:id>
								</ml:apply>
								<ml:unitOverride>
									<ml:id xml:space="preserve">W</ml:id>
								</ml:unitOverride>
								<result xmlns="http://schemas.mathsoft.com/math30">
									<unitedValue>
										<ml:real>31.32897141912505</ml:real>
										<unitMonomial xmlns="http://schemas.mathsoft.com/units10">
											<unitReference unit="watt"/>
										</unitMonomial>
									</unitedValue>
								</result>
							</ml:eval>
						</ml:define>
					</math>
					<rendering item-idref="21"/>
				</region>
				<region region-id="9519" left="102" top="1353.75" width="561" height="9.75" align-x="111.75" align-y="1362" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>根据上述计算，整流桥选型的额定电流值需大于26A，且耐压值需大于507,其散热器能力必须满足31W的损耗散热。</b>
						</p>
					</text>
				</region>
			</area>
			<rendering item-idref="22"/>
		</region>
		<region region-id="9530" left="78" top="1435.5" width="174.75" height="12" align-x="103.5" align-y="1446" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f size="12">
						<b>AC输入X电容计算：</b>
					</f>
				</p>
			</text>
		</region>
		<region region-id="9622" left="0" top="1461" width="6000" align-x="6000" align-y="1470" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="" height="392.25">
			<area is-collapsed="false" name="" show-name="false" show-border="true" show-icon="true" show-timestamp="true" allow-expand="false" is-locked="false" timestamp="" top-lock-id="9622" bottom-lock-id="9520" bottom-tag="">
				<region region-id="9623" left="102" top="1491.75" width="531.75" height="9.75" align-x="111.75" align-y="1500" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>通常情况输入电流纹波系数取0.2~0.5（代表电感电流纹波包络线）</b>
						</p>
					</text>
				</region>
				<region region-id="9563" left="156" top="1516.5" width="74.25" height="13.5" align-x="209.25" align-y="1524" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="I_Ripple">K</ml:id>
							<ml:real>0.5</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="23"/>
				</region>
				<region region-id="9536" left="102" top="1551.75" width="531.75" height="9.75" align-x="111.75" align-y="1560" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>通常情况输入电压纹波系数取0.05~0.08（代表输入电压纹波包络线）</b>
						</p>
					</text>
				</region>
				<region region-id="9558" left="156" top="1582.5" width="89.25" height="13.5" align-x="219.75" align-y="1590" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="VAC_Ripple">K</ml:id>
							<ml:real>0.08</ml:real>
						</ml:define>
					</math>
					<rendering item-idref="24"/>
				</region>
				<region region-id="9542" left="102" top="1617.75" width="531.75" height="9.75" align-x="111.75" align-y="1626" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="普通" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>计算输入电流纹波值：</b>
						</p>
					</text>
				</region>
				<region region-id="9555" left="156" top="1648.5" width="219" height="13.5" align-x="209.25" align-y="1656" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:id xml:space="preserve" subscript="Ripple">Iac</ml:id>
							<ml:eval placeholderMultiplicationStyle="default">
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve" subscript="I_Ripple">K</ml:id>
