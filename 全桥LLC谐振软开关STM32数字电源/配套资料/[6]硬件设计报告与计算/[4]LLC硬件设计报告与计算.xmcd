		<region region-id="499" left="276" top="770.25" width="151.5" height="96" align-x="276" align-y="780" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ur是初始磁导率</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">U0是真空磁导率</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">u是相对磁导率</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">lg是磁芯中柱气息长度</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Ae是磁芯中柱面积</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">le是磁芯闭合回路长度</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">磁芯选择PQ2625</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">谐振电感磁芯：PQ2020</p>
			</text>
		</region>
		<region region-id="500" left="36" top="788.25" width="93.75" height="20.25" align-x="60.75" align-y="804" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:provenance expr-id="1" xmlns:ml="http://schemas.mathsoft.com/math30">
					<originRef doc-id="C97BE1FA-018B-4D27-9A88-47C5208F06DD" version-id="2BD9F8CD-1D21-4A29-A205-ABD678138FC5" branch-id="00000000-0000-0000-0000-000000000000" revision-num="241482212" is-modified="false" region-id="0" href="C:\Users\Yatao\Desktop\LL电感56.xmcd" xmlns="http://schemas.mathsoft.com/provenance10">
