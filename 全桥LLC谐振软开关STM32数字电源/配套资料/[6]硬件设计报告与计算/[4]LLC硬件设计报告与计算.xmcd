					<contentHash xmlns="http://schemas.mathsoft.com/provenance10">80ed71f12ffed2f890f81136b7072cd4</contentHash>
					<ml:define>
						<ml:id xml:space="preserve">lg</ml:id>
						<ml:apply>
							<ml:mult/>
							<ml:real>0.2830450</ml:real>
							<ml:id xml:space="preserve">mm</ml:id>
						</ml:apply>
					</ml:define>
				</ml:provenance>
			</math>
			<rendering item-idref="19">
				<element-image-map>
					<box left="1.5" top="0.75" width="99.75" height="15" expr-idref="1" xmlns="http://schemas.mathsoft.com/worksheet30"/>
				</element-image-map>
