					<originRef doc-id="C97BE1FA-018B-4D27-9A88-47C5208F06DD" version-id="2BD9F8CD-1D21-4A29-A205-ABD678138FC5" branch-id="00000000-0000-0000-0000-000000000000" revision-num="241481972" is-modified="false" region-id="0" href="C:\Users\Yatao\Desktop\LL电感56.xmcd" xmlns="http://schemas.mathsoft.com/provenance10">
